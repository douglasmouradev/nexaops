<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <?define ProductVersion="0.3.1.0" ?>
  <?define UpgradeCode="B7E4A1C2-3D5F-4E89-9A0B-1C2D3E4F5A6B" ?>

  <!-- Defaults injetados no build (build-msi.ps1 -dBakeToken / -dBakeApiUrl).
       Duplo clique no MSI já configura e inicia o agent sem msiexec manual. -->
  <?ifndef BakeToken ?>
    <?define BakeToken=""?>
  <?endif?>
  <?ifndef BakeApiUrl ?>
    <?define BakeApiUrl="https://nexaops.tdesksolutions.com.br"?>
  <?endif?>

  <Product
    Id="*"
    Name="NexaOps Agent"
    Language="1046"
    Version="$(var.ProductVersion)"
    Manufacturer="NexaOps"
    UpgradeCode="$(var.UpgradeCode)">

    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      Platform="x64"
      Description="Agente de monitoramento RMM NexaOps para Windows"
      Comments="Monitora CPU, RAM, disco e interfaces de rede" />

    <MajorUpgrade
      DowngradeErrorMessage="Uma versao mais recente do NexaOps Agent ja esta instalada."
      AllowSameVersionUpgrades="yes" />

    <MediaTemplate EmbedCab="yes" />

    <!-- Valores padrao vêm do build; msiexec TOKEN=/API_URL= ainda sobrescrevem -->
    <Property Id="TOKEN" Secure="yes" Value="$(var.BakeToken)" />
    <Property Id="API_URL" Value="$(var.BakeApiUrl)" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="NexaOps Agent" />
      </Directory>
    </Directory>

    <Feature Id="MainFeature" Title="NexaOps Agent" Level="1">
      <ComponentGroupRef Id="AgentFiles" />
    </Feature>

    <CustomAction
      Id="SetInstallCmd"
      Property="InstallService"
      Value="&quot;[SystemFolder]WindowsPowerShell\v1.0\powershell.exe&quot; -ExecutionPolicy Bypass -NoProfile -File &quot;[INSTALLFOLDER]windows\install.ps1&quot; -InstallFolder &quot;[INSTALLFOLDER]&quot; -Token &quot;[TOKEN]&quot; -ApiUrl &quot;[API_URL]&quot;"
      Execute="immediate" />

    <CustomAction
      Id="InstallService"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Return="check"
      Impersonate="no" />

    <CustomAction
      Id="SetUninstallCmd"
      Property="UninstallService"
      Value="&quot;[SystemFolder]WindowsPowerShell\v1.0\powershell.exe&quot; -ExecutionPolicy Bypass -NoProfile -File &quot;[INSTALLFOLDER]windows\uninstall.ps1&quot;"
      Execute="immediate" />

    <CustomAction
      Id="UninstallService"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Return="ignore"
      Impersonate="no" />

    <InstallExecuteSequence>
      <Custom Action="SetInstallCmd" Before="InstallService">TOKEN AND NOT REMOVE~="ALL"</Custom>
      <Custom Action="InstallService" After="InstallFiles">TOKEN AND NOT REMOVE~="ALL"</Custom>
      <Custom Action="SetUninstallCmd" Before="UninstallService">REMOVE="ALL"</Custom>
      <Custom Action="UninstallService" Before="RemoveFiles">REMOVE="ALL"</Custom>
    </InstallExecuteSequence>

  </Product>
</Wix>
