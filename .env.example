# Database
# XAMPP (padrao): mysql na porta 3306
DATABASE_URL="mysql://nexaops:nexaops@localhost:3306/nexaops"
# Docker Compose (host -> container): porta 3307
# DATABASE_URL="mysql://nexaops:nexaops@localhost:3307/nexaops"

# Redis (BullMQ exige Redis >= 7; use redis:7-alpine no Docker)
REDIS_URL="redis://localhost:6379"
# Em produção, force falha se Redis estiver ausente/incompatível:
# REDIS_REQUIRED=true

# JWT (obrigatório — use valores longos e aleatórios em produção)
JWT_SECRET="change-me-to-a-long-random-secret-in-production"
JWT_REFRESH_SECRET="change-me-to-another-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# API
API_PORT=3001
API_URL="http://localhost:3001"
# Lista separada por vírgula ou, em dev, localhost:* é aceito automaticamente
CORS_ORIGIN="http://localhost:5173"

# Web (vazio = same-origin / proxy Vite)
VITE_API_URL=""

# Encryption (obrigatório — mínimo 32 caracteres para AES-256)
VAULT_ENCRYPTION_KEY="change-me-to-a-32-char-vault-key!!"

# Email (sem SMTP_HOST, e-mails vão para o console; em prod use SMTP_REQUIRED=true)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nexaops.local
# SMTP_REQUIRED=true
# Em production a API exige SMTP_REQUIRED=true + SMTP_HOST
# NOTIFY_CRITICAL_ALERTS=false  # desliga e-mails/webhooks de alerta globalmente
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...  # fallback global (org tem campo próprio)
# ALLOW_DEMO_SEED=true  # necessário para rodar seed com NODE_ENV=production
# AGENT_CURRENT_VERSION=0.5.0
# ALLOW_LOCALHOST_CORS=true  # só se precisar localhost contra API de production
# REMOTE_SESSION_ACK_TIMEOUT_MS=60000

# Object storage (S3 / MinIO) — obrigatório em production (ALLOW_DB_ATTACHMENTS=true só como escape)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=nexaops
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
# ALLOW_DB_ATTACHMENTS=true

# Alerta CRITICAL → ticket URGENT automático (default true)
# AUTO_TICKET_ON_CRITICAL=true

# Remoto prod (templates com {token} {expires} {node} {hostname} {sessionId})
# REMOTE_PROVIDER=native
# WEB_URL=https://nexaops.tdesksolutions.com.br
# REMOTE_PROVIDER=guacamole
# REMOTE_URL_TTL_SEC=3600
# REMOTE_URL_SIGNING_SECRET=
# MESHCENTRAL_URL=
# MESHCENTRAL_URL_TEMPLATE={base}/?viewmode=11&node={node}&session={sessionId}&token={token}&expires={expires}
# GUACAMOLE_URL=
# GUACAMOLE_URL_TEMPLATE={base}/#/client/{node}?session={sessionId}&token={token}&expires={expires}
# NOVNC_URL=
# NOVNC_URL_TEMPLATE={base}/vnc.html?host={hostname}&session={sessionId}&token={token}&expires={expires}
# REMOTE_DEFAULT_USER=
# REMOTE_DEFAULT_PASSWORD=

# Portal: em production o default é NÃO aceitar ?token= (só header/body)
# PORTAL_ALLOW_QUERY_TOKEN=true
# AGENT_ALLOW_QUERY_TOKEN=true

# Remoto: native (stream in-app) | guacamole|meshcentral|novnc | rdp+ALLOW_RDP_REMOTE
# ALLOW_RDP_REMOTE=false

# Observabilidade
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_SENTRY_DSN=

# OpenAI (opcional — sem chave, filtros NL usam parser local)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OAuth — Microsoft (App Center + SSO Entra)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
# ENTRA_TENANT=  # opcional; sobrescreve MICROSOFT_TENANT no SSO

# TURN / ICE (WebRTC experimental)
# ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"}]
# TURN_URL=
# TURN_USER=
# TURN_PASS=

# Stripe (faturas)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SUCCESS_URL=http://localhost:5173/finance/billing?paid=1
# STRIPE_CANCEL_URL=http://localhost:5173/finance/billing?canceled=1

# OAuth — Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Code signing MSI (Authenticode / SmartScreen)
CODE_SIGN_PFX_PATH=
CODE_SIGN_PFX_PASSWORD=
CODE_SIGN_THUMBPRINT=
CODE_SIGN_TIMESTAMP_URL=http://timestamp.digicert.com

# Observabilidade (opcional — requer @sentry/node instalado)
SENTRY_DSN=

# ── Deploy checklist ──────────────────────────────────────────────────────────
# 1. Troque JWT_*, VAULT_ENCRYPTION_KEY e senhas MySQL
# 2. CORS_ORIGIN + API_URL = URLs públicas HTTPS
# 3. REDIS_REQUIRED=true e SMTP_REQUIRED=true + SMTP_HOST
# 4. npm run prod:check
# 5. npm run db:migrate:deploy
# 6. npm run prod:create-admin -- --email ... --password ...
# 7. npm run prod:up   # docker compose + prod overlay
# 8. Rebuild MSI: API_URL=https://api... npm run build:agent-msi (+ CODE_SIGN_*)
# 9. S3_* recomendado; REMOTE_PROVIDER=native|guacamole|meshcentral|novnc
