{
  "name": "nexaops",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w @nexaops/api\" \"npm run dev -w @nexaops/web\"",
    "build": "npm run build -w @nexaops/shared && npm run build -w @nexaops/api && npm run build -w @nexaops/web",
    "test": "npm run test -w @nexaops/api && npm run test -w @nexaops/web",
    "db:generate": "npm run db:generate -w @nexaops/api",
    "db:migrate": "npm run db:migrate -w @nexaops/api",
    "db:migrate:deploy": "npm run db:migrate:deploy -w @nexaops/api",
    "db:seed": "npm run db:seed -w @nexaops/api",
    "db:push": "npm run db:push -w @nexaops/api",
    "build:agent-msi": "powershell -ExecutionPolicy Bypass -File apps/agent/installer/build-msi.ps1",
    "install:wix": "powershell -ExecutionPolicy Bypass -File apps/agent/installer/install-wix.ps1",
    "test:e2e": "npm run test:e2e -w @nexaops/web",
    "backup:mysql": "powershell -ExecutionPolicy Bypass -File scripts/backup-mysql.ps1",
    "backup:mysql:sh": "bash scripts/backup-mysql.sh",
    "watchdog:health": "powershell -ExecutionPolicy Bypass -File scripts/health-watchdog.ps1",
    "watchdog:health:sh": "bash scripts/health-watchdog.sh",
    "prod:check": "tsx scripts/prod-check.ts",
    "prod:create-admin": "tsx scripts/create-admin.ts",
    "prod:up": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
